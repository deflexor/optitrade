# Copy to .env and fill with real values (never commit .env).
# Optional overrides for local development.

DERIBIT_CLIENT_ID=
DERIBIT_CLIENT_SECRET=
# Default JSON-RPC base if unset: https://test.deribit.com/api/v2
DERIBIT_BASE_URL=

# Policy JSON path (e.g. config/examples/policy.example.json) — required for smoke-order
OPTITRADE_POLICY_PATH=

# Must be 1 to allow optitrade smoke-order to submit testnet orders (see docs/quickstart.md)
OPTITRADE_ALLOW_TESTNET_ORDERS=

OPTITRADE_CONFIG_PATH=
