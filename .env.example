# Copy to `.env` in the repo root and adjust (never commit `.env`).
# Go does not load this file automatically — export vars or use `set -a && source .env && set +a`.
#
# Web-only vars for Vite live in `web/.env.example` (prefix `VITE_`).

# --- Deribit (CLI only: `observe`, `smoke-order`; integration tests) ---
# The operator dashboard does not use these for trading — configure Deribit/OKX under Settings in the UI.
DERIBIT_CLIENT_ID=
DERIBIT_CLIENT_SECRET=
# Default in code if empty: https://test.deribit.com/api/v2
DERIBIT_BASE_URL=https://test.deribit.com/api/v2

# --- Policy / smoke-order ---
# Required for `optitrade smoke-order` when not passing -policy
OPTITRADE_POLICY_PATH=config/examples/policy.example.json
# Must be 1/true/yes to allow smoke-order to place testnet orders (safety gate)
OPTITRADE_ALLOW_TESTNET_ORDERS=0

# --- Operator dashboard (BFF) ---
# Encrypts per-operator API keys stored in SQLite (required). Use 32 ASCII chars, 64 hex, or base64 of 32 bytes.
# Makefile `run-dashboard` sets a dev default if unset; production must set explicitly or use KEY_FILE.
OPTITRADE_SETTINGS_SECRET=
# Optional alternative: path to file containing raw 32-byte key
# OPTITRADE_SETTINGS_KEY_FILE=
# Listen address; must match `web/vite.config.ts` proxy target when using Vite dev
OPTITRADE_DASHBOARD_LISTEN=127.0.0.1:8080
# JSON allowlist: version + users[].username + users[].password_hash (bcrypt).
# If empty, the server uses built-in dev credentials: user opti / password opti.
OPTITRADE_DASHBOARD_AUTH_PATH=
# SQLite: sessions + encrypted operator settings (migrations apply on open)
OPTITRADE_DASHBOARD_SESSION_PATH=optitrade-dashboard.sqlite
# Default currency list for overview/P&L when an operator leaves Settings “currencies” blank
OPTITRADE_DASHBOARD_CURRENCIES=BTC,ETH

# --- Development / strategy ---
# Strategy invariant checks in dev (see src/internal/strategy/invariants.go)
OPTITRADE_DEV_INVARIANTS=
